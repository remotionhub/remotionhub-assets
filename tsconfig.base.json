{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": [
    "scripts/**/*.ts",
    "remotion/**/*.ts",
    "remotion/**/*.tsx",
    "vitest.config.ts"
  ],
  "exclude": ["remotion/**/source.raw.tsx"]
}
